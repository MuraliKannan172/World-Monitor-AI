# WorldMonitor AI — environment configuration
# Copy to .env and adjust as needed. No API keys required.

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen2.5:7b
OLLAMA_NUM_CTX=8192

# Scheduling
FEED_INTERVAL_MINUTES=7
FEED_JITTER_SECONDS=60

# Paths (relative to project root)
DB_PATH=data/worldmonitor.db
GAZETTEER_PATH=data/cities1000.txt

# Logging
LOG_LEVEL=INFO
